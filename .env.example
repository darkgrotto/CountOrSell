# ─────────────────────────────────────────────────────────────────────────────
# CountOrSell — Docker environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# JWT secret key — must be at least 32 characters. Keep this private.
# Generate one with:  openssl rand -base64 48
#                 or: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_KEY=CHANGE_ME_replace_with_a_long_random_secret_at_least_32_chars

# Port to expose on the host (the container always listens on 8080 internally)
COS_PORT=8080
